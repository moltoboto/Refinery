  <body>
    <!-- Kagi feeds removed 2026-04-27: allorigins.win proxy broken, feeds not delivering content -->
    <!-- Replaced with Reuters and CNBC for business/world/tech news without celebrity noise -->
    <outline type="rss" xmlUrl="https://feeds.reuters.com/reuters/businessNews"/>
    <outline type="rss" xmlUrl="https://feeds.reuters.com/reuters/technologyNews"/>
    <outline type="rss" xmlUrl="https://www.cnbc.com/id/100727362/device/rss/rss.html"/>
    <outline type="rss" xmlUrl="https://natesnewsletter.substack.com/feed"/>

    <outline title="AI" text="AI">
      <!-- Core lab / research blogs -->
      <outline type="rss" xmlUrl="https://aws.amazon.com/blogs/machine-learning/feed/"/>
      <outline type="rss" xmlUrl="https://blog.google/innovation-and-ai/technology/ai/rss/"/>
      <outline type="rss" xmlUrl="https://news.mit.edu/rss/topic/artificial-intelligence2"/>
