    <!-- Finance folder added 2026-04-27 -->
    <outline title="Finance" text="Finance">
      <!-- Yahoo Finance news -->
      <outline type="rss" xmlUrl="https://finance.yahoo.com/news/rssindex"/>
      <!-- MarketWatch top stories — reliable, broad market coverage -->
      <outline type="rss" xmlUrl="http://feeds.marketwatch.com/marketwatch/topstories/"/>
      <!-- CNBC Mad Money — Cramer's picks and commentary -->
      <outline type="rss" xmlUrl="https://www.cnbc.com/id/100370673/device/rss/rss.html"/>
      <!-- Seeking Alpha — stock analysis and investor commentary -->
      <outline type="rss" xmlUrl="https://seekingalpha.com/market_currents.xml"/>
      <!-- The Motley Fool — long-term stock picks and analysis -->
      <outline type="rss" xmlUrl="https://www.fool.com/feeds/index.aspx"/>
      <!-- Fox Business — markets and business news -->
      <outline type="rss" xmlUrl="http://feeds.foxbusiness.com/foxbusiness/latest"/>
    </outline>

    <outline title="Learning &amp; Skills" text="Learning &amp; Skills">
      <outline type="rss" xmlUrl="https://dailystoic.com/feed/"/>
      <outline type="rss" xmlUrl="https://stratechery.com/feed/"/>
    </outline>

    <outline title="News" text="News">
      <!-- BBC Technology and NYT Technology — scoped to tech to avoid celebrity noise -->
      <outline type="rss" xmlUrl="http://feeds.bbci.co.uk/news/technology/rss.xml"/>
      <outline type="rss" xmlUrl="https://rss.nytimes.com/services/xml/rss/nyt/Technology.xml"/>
      <!-- Google News removed 2026-05-03: meta-aggregator republishes Reuters/BBC/TC/Verge
           articles we already receive directly — structural duplicate generator -->
      <!-- Yahoo News — AP wire + Yahoo-original content, less overlap than Google News -->
      <outline type="rss" xmlUrl="https://news.yahoo.com/rss"/>
      <!-- Fox News — general US news -->
      <outline type="rss" xmlUrl="http://feeds.foxnews.com/foxnews/latest"/>
      <!-- MSN: no standard public RSS feed — access via browser only -->
    </outline>

